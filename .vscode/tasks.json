{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "Debug"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build/Debug"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "dependsOn": "CMake Configure (Debug)"
        },
        {
            "label": "Clean Build (Debug)",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "build/"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Flash (DAPLink)",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32f1x.cfg",
                "-c", "program build/Debug/stm32f103c8t6_vscode_armgcc_daplink_threadX_env.elf verify reset exit"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build & Flash (Debug)",
            "dependsOn": ["Build (Debug)", "Flash (DAPLink)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
